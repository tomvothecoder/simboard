# syntax=docker/dockerfile:1.6

########################################
# Stage 1: Build the Vite React app
########################################
FROM node:24-alpine AS build-stage

ENV CI=true

# Activate repo-pinned pnpm version
RUN corepack enable && corepack prepare pnpm@10.24.0 --activate

WORKDIR /app

# Copy dependency manifests for caching
COPY pnpm-lock.yaml package.json pnpm-workspace.yaml ./

# Install dependencies (with caching)
RUN --mount=type=cache,target=/root/.pnpm-store \
    pnpm install --frozen-lockfile

# Copy source code
COPY . .

# --------------------------------------------------
# Build-time env vars for Vite (must be provided via
# `docker build --build-arg`)
# --------------------------------------------------
ARG VITE_API_BASE_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

# Build the frontend (Vite reads env vars here)
RUN pnpm run build

########################################
# Stage 2: Serve with Nginx
########################################
FROM nginx:1.29.3-alpine AS production-stage

# Copy built static assets
COPY --from=build-stage /app/dist /usr/share/nginx/html

# Copy Nginx configs
COPY ./nginx.conf /etc/nginx/conf.d/default.conf

# Expose port 80 for Traefik
EXPOSE 80

# Healthcheck for Docker / Traefik
HEALTHCHECK --interval=30s --timeout=3s CMD wget -q -O- http://localhost/health || exit 1

# Run Nginx
CMD ["nginx", "-g", "daemon off;"]
